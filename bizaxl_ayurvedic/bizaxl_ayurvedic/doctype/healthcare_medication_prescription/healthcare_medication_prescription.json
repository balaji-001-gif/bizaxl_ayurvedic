   "in_list_view": 1
  },
  {
   "fieldname": "encounter",
   "label": "Encounter",
   "fieldtype": "Link",
   "options": "Patient Encounter"
  },
  {
   "fieldname": "practitioner",
   "label": "Practitioner",
   "fieldtype": "Link",
   "options": "Healthcare Practitioner",
   "in_list_view": 1
  },
  {
   "fieldname": "column_break_pr1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "prescription_date",
   "label": "Prescription Date",
