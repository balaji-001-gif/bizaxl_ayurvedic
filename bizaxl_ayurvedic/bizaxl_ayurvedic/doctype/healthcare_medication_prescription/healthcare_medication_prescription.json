   "default": "Draft",
   "in_standard_filter": 1
  },
  {
   "fieldname": "column_break_pr2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "notes",
   "label": "Notes",
   "fieldtype": "Text Editor",
